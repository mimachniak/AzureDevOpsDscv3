{
    "$schema": "https://aka.ms/dsc/schemas/v3/bundled/resource/manifest.json",
    "type": "AzureDevOps/OrganizationUserPermission",
    "version": "0.1.0",
    "description": "Manages a user's membership in an organization-level (Project Collection) Azure DevOps security group.",
    "tags": [
        "AzureDevOps",
        "DevOps",
        "Organization",
        "Permission",
        "User",
        "Windows",
        "Linux",
        "macOS"
    ],
    "condition": "[not(equals(tryWhich('pwsh'), null()))]",
    "get": {
        "executable": "pwsh",
        "args": [
            "-NoLogo",
            "-NonInteractive",
            "-NoProfile",
            "-ExecutionPolicy",
            "Bypass",
            "-Command",
            "$input | ./devops.organization-user-permission.ps1 Get"
        ],
        "input": "stdin"
    },
    "set": {
        "executable": "pwsh",
        "args": [
            "-NoLogo",
            "-NonInteractive",
            "-NoProfile",
            "-ExecutionPolicy",
            "Bypass",
            "-Command",
            "$input | ./devops.organization-user-permission.ps1 Set"
        ],
        "input": "stdin",
        "implementsPretest": false,
        "return": "state"
    },
    "test": {
        "executable": "pwsh",
        "args": [
            "-NoLogo",
            "-NonInteractive",
            "-NoProfile",
            "-ExecutionPolicy",
            "Bypass",
            "-Command",
            "$input | ./devops.organization-user-permission.ps1 Test"
        ],
        "input": "stdin",
        "return": "state"
    },
    "exitCodes": {
        "0": "Success",
        "1": "Operation failed (API error or unexpected exception)"
    },
    "schema": {
        "embedded": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "AzureDevOps/OrganizationUserPermission",
            "description": "Properties that describe a user's membership in an organization-level Azure DevOps security group.",
            "type": "object",
            "required": [
                "userPrincipalName",
                "permissionLevel",
                "organization",
                "pat"
            ],
            "properties": {
                "userPrincipalName": {
                    "title": "User Principal Name",
                    "description": "The UPN (email address) of the user. Part of the composite key.",
                    "type": "string"
                },
                "permissionLevel": {
                    "title": "Permission Level",
                    "description": "The organization-level security group to manage the user's membership in.",
                    "type": "string",
                    "enum": [
                        "ProjectCollectionAdministrators",
                        "ProjectCollectionBuildAdministrators",
                        "ProjectCollectionBuildServiceAccounts",
                        "ProjectCollectionProxyServiceAccounts",
                        "ProjectCollectionServiceAccounts",
                        "ProjectCollectionTestServiceAccounts",
                        "ProjectCollectionValidUsers",
                        "ProjectScopedUsers",
                        "SecurityServiceGroup"
                    ]
                },
                "organization": {
                    "title": "Organization",
                    "description": "The Azure DevOps organization name. Part of the composite key.",
                    "type": "string"
                },
                "ensure": {
                    "title": "Ensure",
                    "description": "Whether the user should be a member ('Present') or not a member ('Absent') of the group. Defaults to 'Present'.",
                    "type": "string",
                    "enum": [
                        "Present",
                        "Absent"
                    ],
                    "default": "Present"
                },
                "pat": {
                    "title": "Personal Access Token",
                    "description": "A Personal Access Token with 'Graph > Read & manage' permissions.",
                    "type": "string"
                },
                "apiVersion": {
                    "title": "API Version",
                    "description": "Azure DevOps REST API version to use for Graph endpoints. Defaults to '7.1-preview.1'.",
                    "type": "string",
                    "default": "7.1-preview.1"
                },
                "_inDesiredState": {
                    "title": "In Desired State",
                    "description": "Indicates whether the resource is in the desired state. Populated by the Test operation.",
                    "type": [
                        "boolean",
                        "null"
                    ],
                    "default": null
                }
            },
            "additionalProperties": false
        }
    }
}
